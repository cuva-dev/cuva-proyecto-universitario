<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="mainContainer" prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.cuvaproject.controller.PruebaController">
   
   <left>
      <VBox prefHeight="600.0" prefWidth="200.0" spacing="15.0" style="-fx-background-color: #0d1b2a; -fx-padding: 20px;" BorderPane.alignment="CENTER">
         <children>
            <Label text="Menú" textFill="WHITE">
               <font>
                  <Font name="Arial Bold" size="24.0" />
               </font>
               <VBox.margin>
                  <Insets bottom="20.0" />
               </VBox.margin>
            </Label>
            
            <Button mnemonicParsing="false" onAction="#showStudentList" prefHeight="40.0" prefWidth="160.0" style="-fx-background-color: #e67e22; -fx-background-radius: 5;" text="Lista de Estudiantes" textFill="WHITE">
               <font>
                  <Font name="Arial Bold" size="13.0" />
               </font>
            </Button>
            

            
            <Button mnemonicParsing="false" onAction="#showCreateUser" prefHeight="40.0" prefWidth="160.0" style="-fx-background-color: #3498db; -fx-background-radius: 5;" text="Crear Usuario" textFill="WHITE">
               <font>
                  <Font name="Arial Bold" size="13.0" />
               </font>
            </Button>
            
            <VBox prefHeight="200.0" prefWidth="100.0" VBox.vgrow="ALWAYS" />
            
            <Button mnemonicParsing="false" onAction="#handleLogout" prefHeight="35.0" prefWidth="160.0" style="-fx-background-color: #e74c3c; -fx-background-radius: 5;" text="Cerrar Sesión" textFill="WHITE">
               <font>
                  <Font name="Arial Bold" size="13.0" />
               </font>
            </Button>
         </children>
      </VBox>
   </left>
   
   <center>
      </center>
   
</BorderPane>